# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# Database
DATABASE_URL=sqlite:./sokoul_desktop.db?mode=rwc

# Logs
RUST_LOG=sokoul_backend=info,tower_http=info

# --- Content Sources (required) ---
TMDB_API_KEY=
REALDEBRID_API_TOKEN=

# --- Indexers (optional, at least one recommended) ---
PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=

# --- Stream Proxies (optional) ---
WASTREAM_URL=http://localhost:7000       # Wastream DDL proxy
FLARESOLVERR_URL=http://localhost:8191   # FlareSolverr Cloudflare bypass
FLARESOLVERR_PROWLARR_URL=http://localhost:8191  # FlareSolverr URL for Prowlarr proxy config

# --- Artwork & Ratings (optional) ---
FANART_API_KEY=
OMDB_API_KEY=
TVDB_API_KEY=
SIMKL_CLIENT_ID=
WATCHMODE_API_KEY=
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

# --- Artwork Resolver (optional — /artwork endpoint) ---
TOP_POSTERS_API_KEY=    # Top Posters API key (api.top-streaming.stream)
CINEMATERIAL_API_KEY=   # CineMaterial API key (api.cinematerial.com)
